---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Viwra — The Portal',
  description = 'Viwra İlk Halka Seçim Protokolü. Bu bir kayıt formu değil, bir uygunluk testidir.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a062b" />
    <title>{title}</title>

    <!-- Inter font — extra-light & light weights only -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
