---
import Layout from '../layouts/Layout.astro';
import FilmGrain from '../components/FilmGrain.astro';
import ViwraLogo from '../components/ViwraLogo.astro';
import SelectionProtocol from '../components/SelectionProtocol.astro';
import ProtocolModal from '../components/ProtocolModal.astro';
import PostFormFlow from '../components/PostFormFlow.astro';
import '../styles/global.css';
---

<Layout>
  <!-- Film grain (always on top) -->
  <FilmGrain />

  <!-- ═══ HERO SECTION ══════════════════════════════════════════════════ -->
  <section class="hero-section relative" style="height: 220vh;">
    <!-- Sticky inner: stays visible while user scrolls through 220vh -->
    <div class="sticky top-0 h-screen flex flex-col items-center justify-center gap-14 px-6">

      <!-- Breathing logo -->
      <div class="hero-logo opacity-0">
        <ViwraLogo />
      </div>

      <!-- Hero quote -->
      <div class="hero-quote text-center max-w-md">
        <h1 class="text-2xl md:text-[2rem] font-extralight tracking-wide leading-snug text-viwra-bone/85">
          Umuttepe'nin gürültüsü<br />hiç susmuyor, değil mi?
        </h1>
      </div>

      <!-- Faint scroll cue (appears after 2s) -->
      <div class="scroll-cue absolute bottom-10 flex flex-col items-center gap-2 opacity-0">
        <span class="text-viwra-bone/30 text-[10px] tracking-[0.35em] uppercase">Kaydır</span>
        <svg class="text-viwra-bone/30 animate-bounce" width="18" height="18" viewBox="0 0 20 20"
             fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="5 8 10 13 15 8"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- ═══ TRANSITION SECTION ═════════════════════════════════════════════ -->
  <section class="transition-section min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <div class="max-w-md">
      <!-- Label -->
      <p class="transition-label text-viwra-bone/30 text-[10px] tracking-[0.55em] uppercase mb-10 opacity-0">
        İlk Halka &mdash; First Circle
      </p>

      <!-- Main title -->
      <h2 class="transition-title text-2xl md:text-3xl font-extralight tracking-wide text-viwra-bone/90 opacity-0 mb-6">
        Viwra Seçim Protokolü
      </h2>

      <!-- Thin decorative line -->
      <hr class="transition-hr viwra-hr mb-8 scale-x-0 origin-center" />

      <!-- Subtitle -->
      <p class="transition-sub text-viwra-bone/40 text-sm font-extralight tracking-widest leading-loose opacity-0">
        Bu bir kayıt formu değil,<br />bir uygunluk testidir.
      </p>
    </div>
  </section>

  <!-- ═══ PROTOCOL SECTION ════════════════════════════════════════════════ -->
  <SelectionProtocol />

  <!-- ═══ FOOTER ══════════════════════════════════════════════════════════ -->
  <footer class="py-16 flex justify-center">
    <a
      id="protocol-link"
      href="#"
      class="text-viwra-bone text-[10px] tracking-[0.3em] uppercase hover:opacity-30 transition-opacity duration-700 cursor-pointer"
      style="opacity: 0.15;"
      aria-label="Viwra Protocol sürüm bilgisi"
    >
      [Viwra Protocol v1.04]
    </a>
  </footer>

  <!-- Post-form flow overlay (Calibration → Focus → Analysis → Success) -->
  <PostFormFlow />

  <!-- Protocol version modal -->
  <ProtocolModal />
</Layout>

<!-- ═══ GSAP ANIMATIONS ═══════════════════════════════════════════════════ -->
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Set initial states immediately (prevents flash)
  gsap.set('.hero-logo',         { autoAlpha: 0 });
  gsap.set('.hero-quote',        { autoAlpha: 0, y: 18, filter: 'blur(8px)' });
  gsap.set('.scroll-cue',        { autoAlpha: 0 });
  gsap.set('.transition-label',  { autoAlpha: 0 });
  gsap.set('.transition-title',  { autoAlpha: 0, y: 16 });
  gsap.set('.transition-hr',     { scaleX: 0 });
  gsap.set('.transition-sub',    { autoAlpha: 0 });

  // ── 1. Hero entry animations ────────────────────────────────────────────
  const heroTl = gsap.timeline({ delay: 0.4 });

  heroTl
    .to('.hero-logo',  { autoAlpha: 1, duration: 2.0, ease: 'power2.out' })
    .to('.hero-quote', { autoAlpha: 1, y: 0, filter: 'blur(0px)', duration: 1.6, ease: 'power3.out' }, '-=1.2')
    .to('.scroll-cue', { autoAlpha: 1, duration: 1 }, '-=0.4');

  // ── 2. Hero scroll-out ───────────────────────────────────────────────────
  ScrollTrigger.create({
    trigger: '.hero-section',
    start: 'top top',
    end: 'bottom top',
    scrub: 1.8,
    onUpdate: (self) => {
      const p = self.progress;
      // Quote: blur & float up between 0–70%
      const qp = Math.min(1, p / 0.7);
      gsap.set('.hero-quote', {
        opacity: 1 - qp,
        filter: `blur(${qp * 16}px)`,
        y: -55 * qp,
      });
      // Logo: fade out between 20–80%
      const lp = Math.min(1, Math.max(0, (p - 0.2) / 0.6));
      gsap.set('.hero-logo', { opacity: 1 - lp, scale: 1 - 0.18 * lp });
      // Scroll cue: fade out in first 15%
      gsap.set('.scroll-cue', { opacity: Math.max(0, 1 - p / 0.15) });
    },
  });

  // ── 3. Transition section reveal ─────────────────────────────────────────
  const transitionTl = gsap.timeline({
    scrollTrigger: {
      trigger: '.transition-section',
      start: 'top 70%',
      once: true,
    },
  });

  transitionTl
    .to('.transition-label', { autoAlpha: 1, duration: 0.8 })
    .to('.transition-title', { autoAlpha: 1, y: 0, duration: 1.0, ease: 'power3.out' }, '-=0.3')
    .to('.transition-hr',    { scaleX: 1,    duration: 0.8, ease: 'power2.inOut' }, '-=0.4')
    .to('.transition-sub',   { autoAlpha: 1, duration: 0.9 }, '-=0.3');
</script>
